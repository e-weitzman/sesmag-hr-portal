# ── Neon Serverless PostgreSQL ────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/sesmag_hr?sslmode=require

# ── Anthropic Claude API ───────────────────────────────────────
# Get from: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# ── JWT Secret ────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_plus_random_hex_characters

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=SESMag HR Portal
NODE_ENV=development
